{
  "name": "personal-website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:facts && pnpm typecheck && vite build",
    "build:facts": "node scripts/build-facts.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "deploy:prod": "pnpm build && wrangler pages deploy dist --branch=main",
    "deploy:preview": "pnpm build && wrangler pages deploy dist --branch=preview",
    "dev:pages": "pnpm build && wrangler pages dev dist",
    "tail": "wrangler pages deployment tail --project-name personal-website",
    "precompute:match": "node scripts/precompute-match.mjs",
    "new-company": "node scripts/new-company.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "hono": "^4.7.0",
    "posthog-js": "^1.376.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251201.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^3.99.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  }
}
